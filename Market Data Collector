        if v < 0:
            raise ValueError('Volume cannot be negative')
        return v


class ConnectionPool:
    """HTTP Connection Pool"""

    def __init__(self, max_connections: int = 10, timeout: int = 30):
        self.max_connections = max_connections
        self.timeout = aiohttp.ClientTimeout(total=timeout)
        self.connector = None
        self.session = None

    async def __aenter__(self):
        self.connector = aiohttp.TCPConnector(
            limit=self.max_connections,
            limit_per_host=self.max_connections,
            keepalive_timeout=60,
            enable_cleanup_closed=True
        )
        self.session = aiohttp.ClientSession(
            connector=self.connector,
            timeout=self.timeout
        )
        return self.session

    async def __aexit__(self, exc_type, exc_val, exc_tb):
        if self.session:
            await self.session.close()
        if self.connector:
            await self.connector.close()


class DuplicateDetector:
    """Memory-efficient duplicate detection"""

    def __init__(self):
        self.seen_entries: Dict[str, deque] = {}

    def is_duplicate(self, symbol: str, timestamp: str, last_price: float) -> bool:
        key = f"{symbol}_{timestamp}_{last_price}"

        if symbol not in self.seen_entries:
            self.seen_entries[symbol] = deque(maxlen=500)  # Keep last 500 entries

        symbol_entries = self.seen_entries[symbol]

        if key in symbol_entries:
            return True

        symbol_entries.append(key)
        return False

    def cleanup(self):
        """Clean up empty entries"""
        for symbol in list(self.seen_entries.keys()):
            if len(self.seen_entries[symbol]) == 0:
                del self.seen_entries[symbol]


class CompressedCSVWriter:
    """Efficient CSV writer with compression"""

    def __init__(self, filepath: Path, compress: bool = True):
        self.filepath = filepath
        self.compress = compress
        self.is_new_file = not filepath.exists()

    async def write_data(self, data: Dict[str, Any]):
        try:
            if self.compress:
                file_path = f"{self.filepath}.gz"
                if not Path(file_path).exists():
                    self.is_new_file = True

                with gzip.open(file_path, 'at', encoding='utf-8') as f:
                    if self.is_new_file:
                        header = ','.join(data.keys()) + '\n'
                        f.write(header)
                        self.is_new_file = False

                    row = ','.join(str(v) for v in data.values()) + '\n'
                    f.write(row)

            else:
                async with aiofiles.open(self.filepath, mode='a', encoding='utf-8') as f:
                    if self.is_new_file:
                        header = ','.join(data.keys()) + '\n'
                        await f.write(header)
                        self.is_new_file = False

                    row = ','.join(str(v) for v in data.values()) + '\n'
                    await f.write(row)

        except Exception as e:
            logger.error(f"CSV write error: {e}")
            raise


