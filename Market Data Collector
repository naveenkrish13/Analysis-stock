    async def fetch_market_data_batch(self, symbols: List[str], session: aiohttp.ClientSession) -> Optional[Dict]:
        """Efficient batch API calls"""
        if not symbols:
            return None

        access_token = self.config["api_credentials"]["access_token"]
        if not access_token:
            raise ValueError("Access token not configured")

        url = "https://api.upstox.com/v2/market-quote/quotes"
        headers = {
            'Accept': 'application/json',
            'Authorization': f'Bearer {access_token}'
        }

        batch_size = min(self.config["settings"]["batch_size"], 500)
        all_data = {}

        for i in range(0, len(symbols), batch_size):
            batch_symbols = symbols[i:i + batch_size]
            symbol_string = ','.join(batch_symbols)
            params = {'instrument_key': symbol_string}

            try:
                async with session.get(url, headers=headers, params=params) as response:
                    response.raise_for_status()
                    data = await response.json()

                    if data.get('status') == 'success':
                        batch_data = data.get('data', {})
                        all_data.update(batch_data)

            except Exception as e:
                logger.error(f"Batch fetch error: {e}")
                continue

        return all_data if all_data else None

    async def validate_and_save_data(self, symbol: str, raw_data: Dict[str, Any]) -> bool:
        """Validate and save data efficiently - DEBUG VERSION"""
        try:
            # Validate with Pydantic
            try:
                validated_data = MarketQuoteData(**raw_data)
            except ValidationError as e:
                self.status_queue.put(('error', f"Validation failed for {symbol}: {str(e)[:100]}"))
                return False

            # Check duplicates
            if self.duplicate_detector.is_duplicate(
                    symbol, validated_data.timestamp, validated_data.last_price
            ):
                self.status_queue.put(('info', f"Duplicate skipped for {symbol}"))
                return False

            # Prepare CSV data
            timestamp = datetime.now().isoformat()
            csv_data = {
                'timestamp': timestamp,
                'symbol': validated_data.symbol,
                'instrument_token': validated_data.instrument_token,
                'last_price': validated_data.last_price,
                'volume': validated_data.volume,
                'average_price': validated_data.average_price,
                'net_change': validated_data.net_change,
                'open': validated_data.ohlc.open,
                'high': validated_data.ohlc.high,
                'low': validated_data.ohlc.low,
                'close': validated_data.ohlc.close,
                'total_buy_quantity': validated_data.total_buy_quantity,
                'total_sell_quantity': validated_data.total_sell_quantity,
                'oi': validated_data.oi,
                'lower_circuit_limit': validated_data.lower_circuit_limit,
                'upper_circuit_limit': validated_data.upper_circuit_limit,
                'last_trade_time': validated_data.last_trade_time,
                'oi_day_high': validated_data.oi_day_high,
                'oi_day_low': validated_data.oi_day_low
            }

            # Add depth data
            for i in range(5):
                if i < len(validated_data.depth.buy):
                    level = validated_data.depth.buy[i]
                    csv_data.update({
                        f'buy_depth_{i + 1}_qty': level.quantity,
                        f'buy_depth_{i + 1}_price': level.price,
                        f'buy_depth_{i + 1}_orders': level.orders
                    })
                else:
                    csv_data.update({
                        f'buy_depth_{i + 1}_qty': 0,
                        f'buy_depth_{i + 1}_price': 0,
                        f'buy_depth_{i + 1}_orders': 0
                    })

                if i < len(validated_data.depth.sell):
                    level = validated_data.depth.sell[i]
                    csv_data.update({
                        f'sell_depth_{i + 1}_qty': level.quantity,
                        f'sell_depth_{i + 1}_price': level.price,
                        f'sell_depth_{i + 1}_orders': level.orders
                    })
                else:
                    csv_data.update({
                        f'sell_depth_{i + 1}_qty': 0,
                        f'sell_depth_{i + 1}_price': 0,
                        f'sell_depth_{i + 1}_orders': 0
                    })

            # Save to CSV - DEBUG VERSION
            try:
                output_dir = Path(self.config["settings"]["output_folder"])
                output_dir.mkdir(exist_ok=True)

                # Extract clean symbol name for Windows-compatible filename
                if validated_data.symbol:
                    # Remove exchange prefix and invalid characters
                    symbol_name = validated_data.symbol.split(':')[
                        -1] if ':' in validated_data.symbol else validated_data.symbol
                else:
                    # Fallback: extract from instrument key
                    symbol_name = symbol.split('|')[-1] if '|' in symbol else symbol

                # Clean filename by removing invalid Windows characters
                symbol_name = symbol_name.replace(':', '_').replace('|', '_').replace('\\', '_').replace('/', '_')

                current_year = datetime.now().year
                filename = f"{symbol_name}_{current_year}.csv"
                filepath = output_dir / filename

                # DEBUG: Show what we're trying to write
                self.status_queue.put(('info', f"Writing to: {filepath}"))

                writer = CompressedCSVWriter(
                    filepath,
                    compress=self.config["settings"]["enable_compression"]
                )
                await writer.write_data(csv_data)

                # DEBUG: Confirm file was written
                if self.config["settings"]["enable_compression"]:
                    actual_file = Path(f"{filepath}.gz")
                else:
                    actual_file = filepath

                if actual_file.exists():
                    file_size = actual_file.stat().st_size
                    self.status_queue.put(('success', f"✅ File written: {actual_file.name} ({file_size} bytes)"))
                else:
                    self.status_queue.put(('error', f"❌ File not found after write: {actual_file}"))

                return True

            except PermissionError as e:
                self.status_queue.put(('error', f"Permission denied writing {filepath}: {e}"))
                return False
            except OSError as e:
                self.status_queue.put(('error', f"OS error writing {filepath}: {e}"))
                return False
            except Exception as e:
                self.status_queue.put(('error', f"Write error for {symbol}: {type(e).__name__}: {e}"))
                return False

        except Exception as e:
            self.status_queue.put(('error', f"Processing error for {symbol}: {type(e).__name__}: {e}"))
            return False

    async def collection_worker_async(self):
        """Main collection worker"""
        self.start_time = datetime.now()

        max_connections = self.config["settings"]["max_connections"]

        async with ConnectionPool(max_connections=max_connections) as session:
            while not self.stop_event.is_set():
                try:
                    # Check market hours
                    market_open, market_status = self.is_market_open()
                    if not market_open:
                        self.status_queue.put(('status', f"Market: {market_status}"))
                        await asyncio.sleep(60)
                        continue

                    # Get symbols
                    symbols = self.config["watchlist"].copy()
                    if not symbols:
                        self.status_queue.put(('status', "No symbols in watchlist"))
                        await asyncio.sleep(10)
                        continue

                    # Fetch data
                    self.total_requests += 1
                    self.status_queue.put(('status', f"Fetching {len(symbols)} symbols..."))

                    market_data = await self.fetch_market_data_batch(symbols, session)

                    if market_data:
                        # Process concurrently
                        tasks = [self.validate_and_save_data(symbol, data)
                                 for symbol, data in market_data.items()]

                        results = await asyncio.gather(*tasks, return_exceptions=True)
                        saved_count = sum(1 for r in results if r is True)

                        self.successful_requests += 1
                        self.total_collected += saved_count

                        self.status_queue.put(('success', f"Saved {saved_count}/{len(market_data)} symbols"))
                    else:
                        self.status_queue.put(('error', "API fetch failed"))

                    # Cleanup periodically
                    if self.total_requests % 20 == 0:
                        self.duplicate_detector.cleanup()
                        gc.collect()

                    # Wait
                    await asyncio.sleep(self.config["settings"]["poll_interval"])

                except Exception as e:
                    self.status_queue.put(('error', f"Error: {str(e)}"))
                    await asyncio.sleep(10)

        self.status_queue.put(('status', "Collection stopped"))

    def start_collection(self):
        """Start collection"""
        if self.is_collecting:
            return

        if not self.config["api_credentials"]["access_token"]:
            messagebox.showerror("Error", "Configure API access token first!")
            return

        if not self.config["watchlist"]:
            messagebox.showerror("Error", "Add symbols to watchlist first!")
            return

        # Reset stats
        self.total_requests = 0
        self.successful_requests = 0
        self.total_collected = 0
        self.duplicate_detector = DuplicateDetector()

        # Start async collection
        def run_async():
            self.loop = asyncio.new_event_loop()
            asyncio.set_event_loop(self.loop)

            try:
                self.stop_event = asyncio.Event()
                self.collection_task = self.loop.create_task(self.collection_worker_async())
                self.loop.run_until_complete(self.collection_task)
            except Exception as e:
                logger.error(f"Collection error: {e}")
            finally:
                self.loop.close()

        self.collection_thread = threading.Thread(target=run_async, daemon=True)
        self.collection_thread.start()

        # Update UI
        self.is_collecting = True
        self.start_button.config(state=tk.DISABLED)
        self.stop_button.config(state=tk.NORMAL)

    def stop_collection(self):
        """Stop collection"""
        if not self.is_collecting:
            return

        if self.loop and self.stop_event:
            self.loop.call_soon_threadsafe(self.stop_event.set)

        if hasattr(self, 'collection_thread') and self.collection_thread.is_alive():
            self.collection_thread.join(timeout=3.0)

        self.is_collecting = False
        self.start_button.config(state=tk.NORMAL)
        self.stop_button.config(state=tk.DISABLED)

    def cleanup_memory(self):
        """Force cleanup"""
        self.duplicate_detector.cleanup()
        collected = gc.collect()
        messagebox.showinfo("Cleanup", f"Cleaned up {collected} objects")

    def is_market_open(self) -> tuple[bool, str]:
        """Check if market is open"""
        now = datetime.now(self.ist_tz)
        current_time = now.time()
        current_day = now.weekday()

        if current_day >= 5:
            return False, "Weekend"

        try:
            start = dt_time.fromisoformat(self.config["settings"]["trading_start"])
            end = dt_time.fromisoformat(self.config["settings"]["trading_end"])

            if start <= current_time <= end:
                return True, "Open"
            return False, "Closed"

        except ValueError:
            return False, "Error"

    def process_status_queue(self):
        """Update status display"""
        try:
            while True:
                status_type, message = self.status_queue.get_nowait()

                timestamp = datetime.now().strftime("%H:%M:%S")
                self.status_text.config(state=tk.NORMAL)
                self.status_text.insert(tk.END, f"[{timestamp}] {message}\n")
                self.status_text.see(tk.END)

                # Keep last 100 lines
                lines = self.status_text.get(1.0, tk.END).split('\n')
                if len(lines) > 100:
                    self.status_text.delete(1.0, f"{len(lines) - 100}.0")

                self.status_text.config(state=tk.DISABLED)

        except queue.Empty:
            pass

        self.update_display()
        self.root.after(1000, self.process_status_queue)

    def update_display(self):
        """Update time and status"""
        # Current time
        current_time = datetime.now(self.ist_tz).strftime("%H:%M:%S")
        self.current_time_label.config(text=current_time)

        # Market status
        market_open, market_status = self.is_market_open()
        color = "green" if market_open else "red"
        self.market_status_label.config(text=market_status, foreground=color)

        # Show simple stats in title
        if self.is_collecting and self.start_time:
            uptime = datetime.now() - self.start_time
            uptime_str = str(uptime).split('.')[0]
            self.root.title(f"Efficient Collector - Running {uptime_str} | Collected: {self.total_collected}")
        else:
            self.root.title(f"Efficient Collector - Ready | Watchlist: {len(self.config['watchlist'])}")

    def add_symbol(self):
        """Add symbol to watchlist"""
        symbol = self.symbol_entry.get().strip()
        if symbol and symbol not in self.config["watchlist"]:
            self.config["watchlist"].append(symbol)
            self.save_config()
            self.load_watchlist()
            self.symbol_entry.delete(0, tk.END)
        elif symbol in self.config["watchlist"]:
            messagebox.showwarning("Warning", "Symbol already exists!")

    def remove_symbols(self):
        """Remove selected symbols"""
        selections = self.symbol_listbox.curselection()
        if not selections:
            return

        for index in reversed(selections):
            symbol = self.symbol_listbox.get(index)
            self.config["watchlist"].remove(symbol)

        self.save_config()
        self.load_watchlist()

    def clear_watchlist(self):
        """Clear all symbols"""
        if messagebox.askyesno("Confirm", "Clear entire watchlist?"):
            self.config["watchlist"].clear()
            self.save_config()
            self.load_watchlist()

    def load_watchlist(self):
        """Load watchlist into GUI"""
        self.symbol_listbox.delete(0, tk.END)
        for symbol in self.config["watchlist"]:
            self.symbol_listbox.insert(tk.END, symbol)

    def save_settings(self):
        """Save settings"""
        try:
            self.config["api_credentials"]["access_token"] = self.token_entry.get()
            self.config["settings"]["poll_interval"] = int(self.poll_interval_var.get())
            self.config["settings"]["batch_size"] = min(int(self.batch_size_var.get()), 500)
            self.config["settings"]["max_connections"] = int(self.max_conn_var.get())
            self.config["settings"]["output_folder"] = self.folder_var.get()
            self.config["settings"]["enable_compression"] = self.compression_var.get()
            self.config["settings"]["trading_start"] = self.trading_start_var.get()
            self.config["settings"]["trading_end"] = self.trading_end_var.get()

            self.save_config()
            messagebox.showinfo("Success", "Settings saved!")

        except ValueError as e:
            messagebox.showerror("Error", f"Invalid value: {e}")

    def save_config(self):
        """Save config to file"""
        try:
            with open(self.config_file, 'w') as f:
                json.dump(self.config, f, indent=2)
        except Exception as e:
            logger.error(f"Config save error: {e}")

    def on_closing(self):
        """Handle app closing"""
        if self.is_collecting:
            if messagebox.askokcancel("Quit", "Collection is running. Stop and quit?"):
                self.stop_collection()
                self.root.after(1000, self.root.destroy)
            else:
                return
        else:
            self.root.destroy()

    def run(self):
        """Run the application"""
        self.root.mainloop()


if __name__ == "__main__":
    try:
        app = EfficientMarketDataCollector()
        app.run()
    except Exception as e:
        logger.error(f"App error: {e}")
        if 'tk' in globals():
            messagebox.showerror("Error", f"App crashed: {e}")
